# --- Cyberdream Colors ---
set default-bg                "#16181a" # Background
set default-fg                "#ffffff" # Foreground (White)

# Statusbar
set statusbar-bg              "#3c4048" # Grey/Selection
set statusbar-fg              "#ffffff" # White

# Input bar
set inputbar-bg               "#16181a" # Background
set inputbar-fg               "#bd5eff" # Purple/Magenta accent

# Notification colors
set notification-error-bg     "#ff6e5e" # Red
set notification-error-fg     "#ffffff" # White
set notification-warning-bg   "#f1ff5e" # Yellow
set notification-warning-fg   "#16181a" # Background

# Highlight colors (Search/Selection)
set highlight-color           "#5eff6c" # Neon Green
set highlight-active-color    "#5ea1ff" # Blue

# --- Recolor Mode (The "Dark Mode" for PDFs) ---
set recolor                   "true"
set recolor-lightcolor        "#16181a" # This becomes the new "Paper" color
set recolor-darkcolor         "#ffffff" # This becomes the new "Ink" color

# Loading Screen
set render-loading            "true"
set render-loading-fg         "#ffffff"
set render-loading-bg         "#16181a"

# Completion window (Tab menu)
set completion-bg             "#3c4048"
set completion-fg             "#5ef1ff"
set completion-highlight-bg   "#5ea1ff"
set completion-highlight-fg   "#16181a"
