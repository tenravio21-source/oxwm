[global]
    ### Font Settings ###
    font = Maple Mono NF 10
    
    # Vertical padding between lines
    line_height = 4
    
    ### Frame and Spacing ###
    # Using the selection grey for a subtle frame
    frame_width = 3
    frame_color = "#3c4048"
    separator_color = "#3c4048"
    
    # Padding within the notification
    padding = 12
    horizontal_padding = 12
    text_icon_padding = 10

[base16_low]
    msg_urgency = "low"
    background = "#16181a"
    foreground = "#3c4048"  # Dimmer grey for low priority
    timeout = 3

[base16_normal]
    msg_urgency = "normal"
    background = "#16181a"
    foreground = "#ffffff"  # Crisp white for standard alerts
    frame_color = "#5ea1ff" # Blue border to catch the eye
    timeout = 3

[base16_critical]
    msg_urgency = "critical"
    background = "#16181a"
    foreground = "#ff6e5e"  # Neon Red text
    frame_color = "#ff6e5e" # Neon Red border for maximum urgency
    timeout = 0
